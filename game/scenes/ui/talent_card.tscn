[gd_scene format=3]

[node name="TalentCard" type="PanelContainer"]
custom_minimum_size = Vector2(0, 72)

[node name="Margin" type="MarginContainer" parent="."]
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10

[node name="Row" type="HBoxContainer" parent="Margin"]
theme_override_constants/separation = 10

[node name="TextCol" type="VBoxContainer" parent="Margin/Row"]
size_flags_horizontal = 3
theme_override_constants/separation = 3

[node name="Title" type="Label" parent="Margin/Row/TextCol"]
unique_name_in_owner = true
theme_override_font_sizes/font_size = 13
theme_override_colors/font_color = Color(1, 1, 1, 0.96)

[node name="Desc" type="Label" parent="Margin/Row/TextCol"]
unique_name_in_owner = true
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(1, 1, 1, 0.88)
autowrap_mode = 3

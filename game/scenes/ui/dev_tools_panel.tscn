[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/dev_tools_panel.gd" id="1_script"]

[sub_resource type="StyleBoxFlat" id="panel_style"]
content_margin_left = 12.0
content_margin_top = 12.0
content_margin_right = 12.0
content_margin_bottom = 12.0
bg_color = Color(0.08, 0.08, 0.12, 0.95)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.4, 0.5, 0.7, 0.8)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

[node name="DevToolsPanel" type="PanelContainer"]
process_mode = 2
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -280.0
offset_top = 186.0
offset_bottom = 546.0
grow_horizontal = 0
theme_override_styles/panel = SubResource("panel_style")
script = ExtResource("1_script")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Header" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="Title" type="Label" parent="VBoxContainer/Header"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.8, 1.0, 1)
theme_override_font_sizes/font_size = 18
text = "Dev Tools"

[node name="CloseButton" type="Button" parent="VBoxContainer/Header"]
process_mode = 2
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 8
custom_minimum_size = Vector2(56, 32)
text = "X"

[node name="HSeparator" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="LevelSection" type="VBoxContainer" parent="VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Label" type="Label" parent="VBoxContainer/LevelSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.85, 0.7, 1)
theme_override_font_sizes/font_size = 14
text = "Player Level"

[node name="HBoxContainer" type="HBoxContainer" parent="VBoxContainer/LevelSection"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="LevelInput" type="LineEdit" parent="VBoxContainer/LevelSection/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "1"
placeholder_text = "1-100"
max_length = 3

[node name="SetLevelButton" type="Button" parent="VBoxContainer/LevelSection/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "Set"

[node name="MaxLevelButton" type="Button" parent="VBoxContainer/LevelSection/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "Max Level"

[node name="ResetLevelButton" type="Button" parent="VBoxContainer/LevelSection/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "Reset Lvl"

[node name="HSeparator2" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="SpawnSection" type="VBoxContainer" parent="VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Label" type="Label" parent="VBoxContainer/SpawnSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.85, 0.7, 1)
theme_override_font_sizes/font_size = 14
text = "Spawn Mobs"

[node name="HBoxContainer" type="HBoxContainer" parent="VBoxContainer/SpawnSection"]
layout_mode = 2

[node name="Label" type="Label" parent="VBoxContainer/SpawnSection/HBoxContainer"]
layout_mode = 2
text = "Count:"

[node name="SpawnCountInput" type="LineEdit" parent="VBoxContainer/SpawnSection/HBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "1"
placeholder_text = "1-50"
max_length = 2

[node name="HBoxContainer2" type="HBoxContainer" parent="VBoxContainer/SpawnSection"]
layout_mode = 2

[node name="SpawnCommonButton" type="Button" parent="VBoxContainer/SpawnSection/HBoxContainer2"]
unique_name_in_owner = true
layout_mode = 2
text = "Spawn Common"

[node name="SpawnEliteButton" type="Button" parent="VBoxContainer/SpawnSection/HBoxContainer2"]
unique_name_in_owner = true
layout_mode = 2
text = "Spawn Elite"

[node name="HSeparator3" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="ClassSection" type="VBoxContainer" parent="VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Label" type="Label" parent="VBoxContainer/ClassSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.85, 0.7, 1)
theme_override_font_sizes/font_size = 14
text = "Change Class"

[node name="ClassOption" type="OptionButton" parent="VBoxContainer/ClassSection"]
unique_name_in_owner = true
layout_mode = 2

[node name="ApplyClassButton" type="Button" parent="VBoxContainer/ClassSection"]
unique_name_in_owner = true
layout_mode = 2
text = "Apply Class"

[connection signal="pressed" from="VBoxContainer/Header/CloseButton" to="." method="_on_close_pressed"]
[connection signal="text_submitted" from="VBoxContainer/LevelSection/HBoxContainer/LevelInput" to="." method="_on_level_input_submitted"]
[connection signal="text_submitted" from="VBoxContainer/SpawnSection/HBoxContainer/SpawnCountInput" to="." method="_on_spawn_count_input_submitted"]
[connection signal="pressed" from="VBoxContainer/LevelSection/HBoxContainer/SetLevelButton" to="." method="_on_set_level_pressed"]
[connection signal="pressed" from="VBoxContainer/LevelSection/HBoxContainer/MaxLevelButton" to="." method="_on_max_level_pressed"]
[connection signal="pressed" from="VBoxContainer/LevelSection/HBoxContainer/ResetLevelButton" to="." method="_on_reset_level_pressed"]
[connection signal="pressed" from="VBoxContainer/SpawnSection/HBoxContainer2/SpawnCommonButton" to="." method="_on_spawn_common_pressed"]
[connection signal="pressed" from="VBoxContainer/SpawnSection/HBoxContainer2/SpawnEliteButton" to="." method="_on_spawn_elite_pressed"]
[connection signal="pressed" from="VBoxContainer/ClassSection/ApplyClassButton" to="." method="_on_apply_class_pressed"]

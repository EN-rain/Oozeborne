[gd_scene format=3]

[node name="PartyCard" type="PanelContainer"]
custom_minimum_size = Vector2(0, 72)

[node name="Padding" type="MarginContainer" parent="."]
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 8

[node name="Row" type="HBoxContainer" parent="Padding"]
theme_override_constants/separation = 10

[node name="AvatarHolder" type="Control" parent="Padding/Row"]
custom_minimum_size = Vector2(38, 38)

[node name="Avatar" type="ColorRect" parent="Padding/Row/AvatarHolder"]
unique_name_in_owner = true
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="AvatarLetter" type="Label" parent="Padding/Row/AvatarHolder"]
unique_name_in_owner = true
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
horizontal_alignment = 1
vertical_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(1, 1, 1, 0.95)

[node name="TextCol" type="VBoxContainer" parent="Padding/Row"]
size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="NameLabel" type="Label" parent="Padding/Row/TextCol"]
unique_name_in_owner = true
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0, 0, 0, 0.92)

[node name="MetaLabel" type="Label" parent="Padding/Row/TextCol"]
unique_name_in_owner = true
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0, 0, 0, 0.72)

[node name="ClassLabel" type="Label" parent="Padding/Row/TextCol"]
unique_name_in_owner = true
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.5, 0.5, 0.5, 0.6)

[node name="Badge" type="Label" parent="Padding/Row"]
unique_name_in_owner = true
theme_override_font_sizes/font_size = 16
vertical_alignment = 1

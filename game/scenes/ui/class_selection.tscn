; ── Main vertical layout ─────────────────────────────────────────────────────
[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8

; Section header
[node name="TitleLabel" type="Label" parent="VBox"]

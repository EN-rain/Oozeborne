[sub_resource type="Shader" id="top_fade_shader"]
code = "shader_type canvas_item;

uniform vec4 fade_color : source_color = vec4(0.08, 0.05, 0.02, 1.0);

void fragment() {
	float alpha = smoothstep(0.0, 1.0, UV.y);
	COLOR = vec4(fade_color.rgb, fade_color.a * alpha);
}
"

[sub_resource type="ShaderMaterial" id="top_fade_material"]
shader = SubResource("top_fade_shader")
shader_parameter/fade_color = Color(0.08, 0.05, 0.02, 1)


; =============================================================================
; Scene tree
; =============================================================================

[node name="RoomLobby" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_roomlobby")

; Full-screen background
[node name="Background" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("bg_panel")

; Two-column split
[node name="HBox" type="HBoxContainer" parent="Background"]
layout_mode = 2
theme_override_constants/separation = 0

; ── LEFT PANEL ───────────────────────────────────────────────────────────────
[node name="LeftPanel" type="PanelContainer" parent="Background/HBox"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_stretch_ratio = 1.0
theme_override_styles/panel = SubResource("left_panel_style")

[node name="LeftContent" type="VBoxContainer" parent="Background/HBox/LeftPanel"]
layout_mode = 2
theme_override_constants/separation = 16
alignment = 1

[node name="TitleLabel" type="Label" parent="Background/HBox/LeftPanel/LeftContent"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.92, 1, 1)
theme_override_font_sizes/font_size = 56
text = "ROOM LOBBY"

[node name="SubtitleLabel" type="Label" parent="Background/HBox/LeftPanel/LeftContent"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.55, 0.7, 0.75)
theme_override_font_sizes/font_size = 16
text = "Waiting for players to join..."

[node name="Spacer" type="Control" parent="Background/HBox/LeftPanel/LeftContent"]
custom_minimum_size = Vector2(0, 32)
layout_mode = 2

; Room code row
[node name="CodeRow" type="HBoxContainer" parent="Background/HBox/LeftPanel/LeftContent"]
layout_mode = 2
theme_override_constants/separation = 12
alignment = 0

[node name="CodeBadge" type="PanelContainer" parent="Background/HBox/LeftPanel/LeftContent/CodeRow"]
layout_mode = 2
size_flags_horizontal = 0
theme_override_styles/panel = SubResource("code_badge_style")

[node name="RoomCodeLabel" type="Label" parent="Background/HBox/LeftPanel/LeftContent/CodeRow/CodeBadge"]
layout_mode = 2
theme_override_colors/font_color = Color(0.75, 0.82, 1, 1)
theme_override_font_sizes/font_size = 22
text = "Room Code: ..."

[node name="CopyCodeButton" type="Button" parent="Background/HBox/LeftPanel/LeftContent/CodeRow"]
layout_mode = 2
theme_override_colors/font_color = Color(0.75, 0.85, 1, 0.9)
theme_override_font_sizes/font_size = 14
theme_override_styles/normal = SubResource("btn_copy_normal")
theme_override_styles/hover = SubResource("btn_copy_hover")
theme_override_styles/pressed = SubResource("btn_copy_pressed")
text = "Copy"

; ── RIGHT PANEL ──────────────────────────────────────────────────────────────
[node name="RightPanel" type="PanelContainer" parent="Background/HBox"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_stretch_ratio = 0.9
theme_override_styles/panel = SubResource("right_panel_style")

[node name="RightContent" type="VBoxContainer" parent="Background/HBox/RightPanel"]
layout_mode = 2
theme_override_constants/separation = 20

; Players section header
[node name="PlayersLabel" type="Label" parent="Background/HBox/RightPanel/RightContent"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.75, 0.9, 0.85)
theme_override_font_sizes/font_size = 13
text = "PLAYERS"

; Players card
[node name="PlayersCard" type="PanelContainer" parent="Background/HBox/RightPanel/RightContent"]
layout_mode = 2
theme_override_styles/panel = SubResource("players_card_style")

[node name="PlayersList" type="VBoxContainer" parent="Background/HBox/RightPanel/RightContent/PlayersCard"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Separator" type="HSeparator" parent="Background/HBox/RightPanel/RightContent"]
layout_mode = 2
theme_override_styles/separator = SubResource("separator_style")

; Flexible spacer to push buttons to the bottom
[node name="Spacer" type="Control" parent="Background/HBox/RightPanel/RightContent"]
layout_mode = 2
size_flags_vertical = 3

; Action buttons
[node name="StartButton" type="Button" parent="Background/HBox/RightPanel/RightContent"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 20
theme_override_styles/normal = SubResource("btn_start_normal")
theme_override_styles/hover = SubResource("btn_start_hover")
theme_override_styles/pressed = SubResource("btn_start_pressed")
text = "Start Game"

[node name="BackButton" type="Button" parent="Background/HBox/RightPanel/RightContent"]
layout_mode = 2
theme_override_colors/font_color = Color(0.85, 0.55, 0.55, 0.9)
theme_override_font_sizes/font_size = 16
theme_override_styles/normal = SubResource("btn_back_normal")
theme_override_styles/hover = SubResource("btn_back_hover")
theme_override_styles/pressed = SubResource("btn_back_pressed")
text = "Back to Menu"

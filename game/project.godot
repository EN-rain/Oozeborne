; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NewGame"
run/main_scene="res://scenes/ui/auth_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

McpInteractionServer="*res://mcp_interaction_server.gd"
Nakama="*uid://bmf6nk0fuaur8"
MultiplayerManager="*res://scripts/globals/multiplayer_manager.gd"
NetworkMessaging="*res://scripts/globals/network_messaging.gd"
MultiplayerUtils="*res://scripts/globals/multiplayer_utils.gd"
PlayerSkillManager="*res://scripts/globals/player_skill_manager.gd"
StatusEffectManager="*res://scripts/globals/status_effect_manager.gd"
LevelSystem="*res://scripts/globals/level_system.gd"
SkillRegistry="*res://scripts/globals/skill_registry.gd"
SkillTreeManager="*res://scripts/globals/skill_tree_manager.gd"
DamageNumbers="*res://scenes/autoload/damage_numbers.tscn"
CoinManager="*res://scenes/autoload/coin_manager.tscn"
ShopManager="*res://scripts/globals/shop_manager.gd"
SlimePaletteRegistry="*res://scripts/globals/slime_palette_registry.gd"
ClassManager="*res://scenes/autoload/class_manager.tscn"
SoloRunSaveManager="*res://scripts/globals/solo_run_save_manager.gd"
AdminManager="*res://scripts/globals/admin_manager.gd"
CloudSaveManager="*res://scripts/globals/cloud_save_manager.gd"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/com.heroiclabs.nakama/plugin.cfg")

[global_group]

player=""
enemy=""
common_mob=""
elite_mob=""
boss_mob=""


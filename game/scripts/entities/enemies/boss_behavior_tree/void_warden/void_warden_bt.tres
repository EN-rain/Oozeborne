[sub_resource type="BTSequence" id="BTSequence_combat"]
children = [SubResource("BTAction_detect"), SubResource("BTCondition_hasplayer"), SubResource("BTAction_chase"), SubResource("BTRandomSelector_skills")]

[sub_resource type="BTAction" id="BTAction_idle"]
script = ExtResource("9_idle")

[sub_resource type="BTSelector" id="BTSelector_boss"]
children = [SubResource("BTSequence_combat"), SubResource("BTAction_idle")]

[resource]

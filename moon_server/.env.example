# Moon Server Environment Variables
# Copy this file to .env and fill in your values

# ── Postgres ──────────────────────────────────────────
POSTGRES_USER=moon
POSTGRES_PASSWORD=moonpass
POSTGRES_DB=moondb
DATABASE_URL=postgres://moon:moonpass@postgres:5432/moondb

# ── Redis ─────────────────────────────────────────────
REDIS_ADDR=redis:6379

# ── JWT / Auth ────────────────────────────────────────
JWT_SECRET=change_me_before_production
PORTAL_TOKEN_SECRET=change_me_before_production
JWT_EXPIRES_IN=7d

# ── Game Server ───────────────────────────────────────
GAME_SERVER_PORT=8080
TICKRATE=20
WORLD_BOUNDS_X=800
WORLD_BOUNDS_Y=600
ATTACK_COOLDOWN_MS=500
ATTACK_RANGE=60.0
PLAYER_RADIUS=6.0
INPUT_QUEUE_MAX=10
DISCONNECT_GRACE_SECONDS=15
AFK_TIMEOUT_SECONDS=120

# ── Lobby API ─────────────────────────────────────────
LOBBY_API_PORT=3000

# ── Admin Portal ──────────────────────────────────────
ADMIN_PORTAL_PORT=3001
NEXT_PUBLIC_LOBBY_API_URL=http://localhost:3000
NEXT_PUBLIC_GAME_SERVER_URL=ws://localhost:8080

# ── Super Admin (default — change on first boot) ──────
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin
